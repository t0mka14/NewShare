{
  "schemaVersion": 1,
  "configVersion": "2026-07-01.1-editor-disabled",
  "defaultLanguage": "cs",
  "languages": [
    "cs",
    "en"
  ],
  "defaultMicName": "USBAudioDevice",
  "enableEditor": false,
  "indicatorType": "CIRCLE",
  "patientFields": [
    {
      "name": "code",
      "labelKey": "patient_code_label",
      "helpKey": "patient_code_help",
      "placeholder": "HC001",
      "regex": "[a-zA-Z0-9_-]+",
      "required": true,
      "useInFilename": true
    },
    {
      "name": "visitNumber",
      "labelKey": "patient_visit_number_label",
      "helpKey": "patient_visit_number_help",
      "placeholder": "V0",
      "regex": "V\\d+",
      "required": true,
      "useInFilename": true
    },
    {
      "name": "sex",
      "labelKey": "patient_sex_label",
      "helpKey": "patient_sex_help",
      "placeholder": "F/M",
      "regex": "",
      "required": false,
      "useInFilename": false
    }
  ],
  "protocols": [
    {
      "name": "Share",
      "manualFilePath": "protocol_manuals/MDSE_app_manual 2024.pdf",
      "recordingsFileName": "${installationId}_${patientCode}_${taskIndex}_${task.subtype}_Rep${repetition}",
      "tasks": [
        {
          "type": "CALIBRATION",
          "titleKey": "calibration_title",
          "instructionKeys": [
            "calibration_instructions"
          ],
          "optimalLoudness": [
            0.2,
            0.5
          ]
        },
        {
          "type": "VOCAL",
          "subtype": "PHONATION",
          "titleKey": "phonation_title",
          "instructionKeys": [
            "phonation_instructions1",
            "phonation_instructions2"
          ],
          "length": 10,
          "showIndicator": true,
          "canRepeat": true,
          "canSkip": false,
          "audioExamplePath": "audio_instructions/aaa.wav",
          "nrepetition": 2
        },
        {
          "type": "QUESTIONNAIRE",
          "titleKey": "questionnaire_title",
          "length": 200,
          "canRepeat": false,
          "canSkip": false,
          "nrepetition": 1,
          "questions": [
            {
              "questionType": "OPEN",
              "questionKey": "smoking_status",
              "questionTextKey": "question_smoking_status_text",
              "questionRegex": ".*"
            },
            {
              "questionType": "SINGLE_CHOICE",
              "questionKey": "voice_fatigue",
              "questionTextKey": "question_voice_fatigue_text",
              "questionOptions": [
                "option_yes",
                "option_no"
              ]
            }
          ]
        },
        {
          "type": "INFO",
          "titleKey": "info_title",
          "instructionKeys": [
            "info_done"
          ]
        }
      ]
    },
    {
      "name": "QuestionnaireOnly",
      "manualFilePath": "protocol_manuals/questionnaire_only_manual.pdf",
      "recordingsFileName": "${installationId}_${patientCode}_${taskIndex}_${task.subtype}_Rep${repetition}",
      "tasks": [
        {
          "type": "QUESTIONNAIRE",
          "titleKey": "intake_questionnaire_title",
          "length": 120,
          "canRepeat": false,
          "canSkip": false,
          "nrepetition": 1,
          "questions": [
            {
              "questionType": "OPEN",
              "questionKey": "intake_notes",
              "questionTextKey": "question_intake_notes_text",
              "questionRegex": ".*"
            },
            {
              "questionType": "MULTIPLE_CHOICE",
              "questionKey": "symptoms",
              "questionTextKey": "question_symptoms_text",
              "questionOptions": [
                "symptom_hoarseness",
                "symptom_fatigue",
                "symptom_pain"
              ]
            }
          ]
        },
        {
          "type": "INFO",
          "titleKey": "info_title",
          "instructionKeys": [
            "info_done"
          ]
        }
      ]
    }
  ],
  "strings": {
    "cs": {
